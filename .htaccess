# ============================================================================
#  Security hardening — Presidential MSME Awards
# ============================================================================

# ----- Force HTTPS (skip local development hosts) --------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)$ [NC]
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ----- Security response headers -------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  # HSTS only over HTTPS (browsers ignore it on plain HTTP anyway).
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" "expr=%{HTTPS} == 'on'"
  # Content Security Policy. 'unsafe-inline' is required by the current inline
  # styles/scripts; tighten with nonces/hashes later if the markup is refactored.
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com https://cdn.jsdelivr.net; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://challenges.cloudflare.com; connect-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com"
  Header always unset X-Powered-By
</IfModule>

# ----- Block public access to sensitive files ------------------------------
<IfModule mod_authz_core.c>
  <FilesMatch "(^\.env$|^\.env\..*|^\.git.*|composer\.(json|lock)|package(-lock)?\.json|\.log$)">
    Require all denied
  </FilesMatch>
</IfModule>
<IfModule !mod_authz_core.c>
  <FilesMatch "(^\.env$|^\.env\..*|^\.git.*|composer\.(json|lock)|package(-lock)?\.json|\.log$)">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>

# ----- Block direct browsing of internal directories -----------------------
RedirectMatch 404 /\.git(/|$)
RedirectMatch 404 /vendor/.*
RedirectMatch 404 /storage/.*

# ----- Disable directory listing -------------------------------------------
Options -Indexes
