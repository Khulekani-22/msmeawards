# Environment variables for the Node.js contact API.
# ---------------------------------------------------------------------------
# Local dev:  copy to ".env" and run `vercel dev`.
# Production: set these in the Vercel dashboard (Project → Settings →
#             Environment Variables). NEVER commit the real .env.
# ---------------------------------------------------------------------------

# Resend (https://resend.com) — sending-only API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Must be an address on a domain verified in your Resend account
RESEND_FROM_EMAIL=info@your-domain.org
# Where contact-form messages are delivered (defaults to RESEND_FROM_EMAIL)
CONTACT_TO_EMAIL=info@your-domain.org

# Comma-separated production origins allowed to submit the form
# (localhost/127.0.0.1 and the Vercel preview URL are always allowed)
ALLOWED_ORIGINS=https://your-domain.org,https://www.your-domain.org

# Secret used to sign stateless CSRF tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=

# Cloudflare Turnstile (optional bot protection). Leave blank to disable.
TURNSTILE_SECRET_KEY=
# Public site key is embedded in the front-end build:
VITE_TURNSTILE_SITEKEY=

# Durable rate limiting via Vercel KV or Upstash Redis (optional but
# recommended on serverless — without it, rate limiting is skipped).
# Vercel KV auto-injects KV_REST_API_URL / KV_REST_API_TOKEN when you add the
# integration; Upstash uses UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN.
KV_REST_API_URL=
KV_REST_API_TOKEN=
