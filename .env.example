# Environment variables for the Node.js contact API.
# ---------------------------------------------------------------------------
# Local dev:  copy to ".env" and run `vercel dev`.
# Production: set these in the Vercel dashboard (Project → Settings →
#             Environment Variables). NEVER commit the real .env.
# ---------------------------------------------------------------------------

# Resend (https://resend.com) — sending-only API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# The "from" address. MUST be on a domain verified in your Resend account.
# IMPORTANT: do NOT make this the same mailbox as CONTACT_TO_EMAIL. If your
# recipient domain is on Microsoft 365 / Google Workspace, sending as one of
# the tenant's own accepted domains (e.g. info@ or noreply@your-domain.org)
# from an external server (Resend) to a mailbox in that SAME tenant is treated
# as intra-org spoofing and gets Quarantined/Junked even when SPF+DKIM+DMARC
# pass and Resend returns HTTP 200. Prefer a dedicated sender on a sending
# subdomain that is NOT an accepted domain in your mail tenant, e.g.
# no-reply@send.your-domain.org
RESEND_FROM_EMAIL=no-reply@send.your-domain.org
# Friendly display name shown to recipients (optional).
RESEND_FROM_NAME=Presidential MSME Awards
# Where contact-form messages are delivered. Keep this DIFFERENT from
# RESEND_FROM_EMAIL (e.g. info@your-domain.org).
CONTACT_TO_EMAIL=info@your-domain.org

# Diagnostics/deliverability: set to 1 to OMIT the Reply-To header. The form
# normally sets Reply-To to the visitor so staff can reply directly, but a
# From-vs-Reply-To domain mismatch can trip Mimecast/M365 impersonation
# protection. Toggle this (no code change) to test whether Reply-To is the
# cause; leave blank/0 to keep one-click reply to the enquirer.
CONTACT_DISABLE_REPLY_TO=

# Comma-separated production origins allowed to submit the form
# (localhost/127.0.0.1 and the Vercel preview URL are always allowed)
ALLOWED_ORIGINS=https://your-domain.org,https://www.your-domain.org

# Secret used to sign stateless CSRF tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=

# Cloudflare Turnstile (optional bot protection). Leave blank to disable.
TURNSTILE_SECRET_KEY=
# Public site key is embedded in the front-end build:
VITE_TURNSTILE_SITEKEY=

# Durable rate limiting via Vercel KV or Upstash Redis (optional but
# recommended on serverless — without it, rate limiting is skipped).
# Vercel KV auto-injects KV_REST_API_URL / KV_REST_API_TOKEN when you add the
# integration; Upstash uses UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN.
KV_REST_API_URL=
KV_REST_API_TOKEN=
